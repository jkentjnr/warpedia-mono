*~
.directory
.Trash-*
.nfs*

# ---------------------------------------------------------------------------
# Editors and IDEs
# ---------------------------------------------------------------------------

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# VS Code (keep workspace settings shareable; ignore per-user state)
