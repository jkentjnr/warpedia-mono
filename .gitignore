!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# Sublime
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*.swn
*.bak
*.tmp
\#*\#
.\#*

