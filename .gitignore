.playwright-mcp/
playwright-report/
test-results/
playwright/.cache/

# Cypress
cypress/screenshots/
cypress/videos/
cypress/downloads/

# Coverage
coverage/

# ---------------------------------------------------------------------------
# Local-only / scratch
# ---------------------------------------------------------------------------

# Stray screenshots saved to the repo root from ad-hoc browser testing
# (does NOT match docs/design/system/screenshots/*.png — those are tracked
# design assets in a subdirectory)
/*.png
/*.jpg
/*.jpeg
/*.gif

# Common scratch dirs
/scratch/
/tmp/
/.tmp/
.cache/
